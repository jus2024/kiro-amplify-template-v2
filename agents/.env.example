# ===========================================
# エージェント用環境変数テンプレート
# このファイルを .env にコピーして使用してください
# 実際の値はコミットしないでください
# ===========================================

# AWS リージョン
# AWS_REGION=us-west-2

# Bedrock モデル ID（例）
# MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0

# ログレベル
# LOG_LEVEL=INFO

# --- AgentCore Runtime デプロイ時に必要な環境変数 ---
# 以下は agentcore launch 後に update-agent-runtime で設定します
# .env には記載しても Runtime に自動反映されません

# エージェントが使用する外部サービスの API キー（必要に応じて追加）
# EXTERNAL_API_KEY=

# フロントエンド側で設定する AgentCore Runtime ARN
# （Amplify コンソールの環境変数に設定）
# NEXT_PUBLIC_AGENTCORE_RUNTIME_ARN=
